    <script>
        function enterSite() {
            const overlay = document.getElementById('entryOverlay');
            const wrapper = document.getElementById('mainWrapper');
            const mainAudio = document.getElementById('mainAudio');
            
            overlay.classList.add('opacity-0');
            setTimeout(() => overlay.classList.add('hidden'), 700);
            
            wrapper.classList.remove('blur-xl', 'pointer-events-none', 'h-screen', 'overflow-hidden');
            
            mainAudio.play().catch(e => console.log("Audio block:", e));
            updateMainAudioUI(true);
        }

        function updateMainAudioUI(isPlaying) {
            const icon = document.getElementById('audioIcon');
            const text = document.getElementById('audioText');
            if(isPlaying) {
                icon.classList.remove('rounded-full', 'animate-pulse');
                icon.classList.add('rounded-sm');
                text.innerText = "Pause Announcement";
            } else {
                icon.classList.add('rounded-full', 'animate-pulse');
                icon.classList.remove('rounded-sm');
                text.innerText = "Play Announcement";
            }
        }

        function toggleMainAudio() {
            const audio = document.getElementById('mainAudio');
            if(audio.paused) {
                audio.play();
                updateMainAudioUI(true);
            } else {
                audio.pause();
                updateMainAudioUI(false);
            }
        }

        function openTelegramModal() {
            const mainAudio = document.getElementById('mainAudio');
            if(!mainAudio.paused) {
                mainAudio.pause();
                updateMainAudioUI(false);
            }

            const modal = document.getElementById('telegramModal');
            const priceSpan = document.getElementById('dynamicPrice');
            const teleLink = document.getElementById('telegramLink');
            
            const price = targetSlots < 1152 ? 50 : 100;
            priceSpan.innerText = price;
            
            const currentUid = document.getElementById('gameUid').value;
            let msg = `Hi bhai muza Uniqe Code buy karna hai in ₹${price}.`;
            if (currentUid.trim().length > 0) {
                msg += ` Mera Game UID: ${currentUid} hai.`;
            }

            const encodedText = encodeURIComponent(msg);
            teleLink.href = `https://t.me/Dragontournament_xyz?text=${encodedText}`;
            
            modal.classList.remove('hidden');
            setTimeout(() => modal.classList.remove('opacity-0'), 10);
            document.body.style.overflow = 'hidden';

            const waAudio = document.getElementById('waAudio');
            waAudio.play().catch(e => console.log("WA Audio blocked:", e));
            document.getElementById('waAudioIcon').innerText = "⏸";
            document.getElementById('waAudioText').innerText = "Pause Voice Note";
        }

        function closeTelegramModal() {
            const modal = document.getElementById('telegramModal');
            modal.classList.add('opacity-0');
            
            const waAudio = document.getElementById('waAudio');
            waAudio.pause();
            waAudio.currentTime = 0;
            document.getElementById('waAudioIcon').innerText = "▶";
            document.getElementById('waAudioText').innerText = "Play Voice Note";

            setTimeout(() => {
                modal.classList.add('hidden');
                document.body.style.overflow = '';
            }, 300);
        }

        function toggleWaAudio() {
            const audio = document.getElementById('waAudio');
            const icon = document.getElementById('waAudioIcon');
            const text = document.getElementById('waAudioText');
            
            if(audio.paused) {
                audio.play();
                icon.innerText = "⏸";
                text.innerText = "Pause Voice Note";
            } else {
                audio.pause();
                icon.innerText = "▶";
                text.innerText = "Play Voice Note";
            }
        }

        function openRewardsModal() {
            const modal = document.getElementById('rewardsModal');
            modal.classList.remove('hidden');
            setTimeout(() => modal.classList.remove('opacity-0'), 10);
            document.body.style.overflow = 'hidden';
            showRoundCard(1);
        }

        function closeRewardsModal() {
            const modal = document.getElementById('rewardsModal');
            modal.classList.add('opacity-0');
            setTimeout(() => {
                modal.classList.add('hidden');
                document.body.style.overflow = ''; 
            }, 500); 
        }

        function showRoundCard(roundNum) {
            [1, 2, 3].forEach(num => {
                document.getElementById('roundCard' + num).classList.add('hidden');
                const btn = document.getElementById('tab' + num);
                btn.classList.remove('bg-gold', 'text-black', 'scale-105');
                btn.classList.add('text-white');
            });
            const card = document.getElementById('roundCard' + roundNum);
            const activeBtn = document.getElementById('tab' + roundNum);
            
            card.classList.remove('hidden');
            activeBtn.classList.remove('text-white');
            activeBtn.classList.add('bg-gold', 'text-black', 'scale-105');
            
            if(window.innerWidth < 768) {
                setTimeout(() => card.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
            }
        }

        const canvas = document.getElementById('particleCanvas');
        const ctx = canvas.getContext('2d');
        let width, height, particles = [], mouse = { x: null, y: null };

        function initCanvas() {
            width = canvas.width = window.innerWidth;
            height = canvas.height = window.innerHeight;
            particles = [];
            const particleCount = window.innerWidth < 768 ? 40 : 100;
            for(let i = 0; i < particleCount; i++) {
                particles.push({
                    x: Math.random() * width, y: Math.random() * height,
                    radius: Math.random() * 1.5, vx: (Math.random() - 0.5) * 0.3, vy: (Math.random() - 0.5) * 0.3,
                    alpha: Math.random() * 0.5 + 0.1
                });
            }
        }

        function animateCanvas() {
            requestAnimationFrame(animateCanvas);
            ctx.clearRect(0, 0, width, height);
            particles.forEach(p => {
                p.x += p.vx; p.y += p.vy;
                if (mouse.x != null && mouse.y != null) {
                    let dx = mouse.x - p.x, dy = mouse.y - p.y;
                    if (Math.sqrt(dx * dx + dy * dy) < 150) { p.x -= dx * 0.01; p.y -= dy * 0.01; }
                }
                if (p.x < 0) p.x = width; if (p.x > width) p.x = 0;
                if (p.y < 0) p.y = height; if (p.y > height) p.y = 0;
                ctx.beginPath(); ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(212, 175, 55, ${p.alpha})`; ctx.shadowBlur = 10; ctx.shadowColor = '#d4af37'; ctx.fill();
            });
        }
        window.addEventListener('resize', initCanvas);
        window.addEventListener('mousemove', (e) => { mouse.x = e.x; mouse.y = e.y; });
        window.addEventListener('mouseout', () => { mouse.x = null; mouse.y = null; });
        initCanvas(); animateCanvas();

        const revealElements = document.querySelectorAll('.reveal');
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => { if (entry.isIntersecting) { entry.target.classList.add('active'); revealObserver.unobserve(entry.target); } });
        }, { threshold: 0.1 });
        revealElements.forEach(el => revealObserver.observe(el));

        const MAX_SLOTS = 2304;
        let targetSlots = 0;
        const currentEl = document.getElementById('slotCurrent');
        const nextEl = document.getElementById('slotNext');
        const progressBar = document.getElementById('slotProgressBar');
        const discountNotice = document.getElementById('discountNotice');
        const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbx_o_i1Db0HKJIH_wjG4sJW7tL9DyRPqRUMen88i_mJMerKVjwuBjZV0S20tFCQN0bt/exec';

        function animateCounterOnLoad(start, end, duration) {
            let startTimestamp = null;
            const step = (timestamp) => {
                if (!startTimestamp) startTimestamp = timestamp;
                const progress = Math.min((timestamp - startTimestamp) / duration, 1);
                const easeProgress = 1 - Math.pow(1 - progress, 3); 
                currentEl.innerText = Math.floor(easeProgress * (end - start) + start);
                if (progress < 1) { window.requestAnimationFrame(step); } 
                else { updateVisualStates(end); }
            };
            window.requestAnimationFrame(step);
        }

        function updateVisualStates(value) {
            progressBar.style.width = `${(value / MAX_SLOTS) * 100}%`;
            if (value < 1152) {
                discountNotice.classList.remove('hidden');
                setTimeout(() => discountNotice.classList.add('opacity-100'), 100);
            } else {
                discountNotice.classList.add('hidden');
                discountNotice.classList.remove('opacity-100');
            }
        }

        function rollToNewNumber(newNumber) {
            if (newNumber === parseInt(currentEl.innerText)) return; 
            nextEl.innerText = newNumber;
            currentEl.classList.remove('translate-y-0'); currentEl.classList.add('-translate-y-full', 'opacity-0');
            nextEl.classList.remove('translate-y-full'); nextEl.classList.add('translate-y-0');
            setTimeout(() => {
                currentEl.classList.remove('transition-transform', 'duration-700', 'ease-in-out');
                nextEl.classList.remove('transition-transform', 'duration-700', 'ease-in-out');
                currentEl.innerText = newNumber;
                currentEl.classList.remove('-translate-y-full', 'opacity-0'); currentEl.classList.add('translate-y-0');
                nextEl.classList.remove('translate-y-0'); nextEl.classList.add('translate-y-full');
                setTimeout(() => {
                    currentEl.classList.add('transition-transform', 'duration-700', 'ease-in-out');
                    nextEl.classList.add('transition-transform', 'duration-700', 'ease-in-out');
                }, 50);
                updateVisualStates(newNumber);
            }, 700); 
        }

        async function fetchLiveCount(isInitialLoad = false) {
            try {
                const response = await fetch(SCRIPT_URL);
                const data = await response.json();
                if (data.status === 'success') {
                    const fetchedCount = data.totalCount;
                    if (isInitialLoad) {
                        targetSlots = fetchedCount;
                        currentEl.classList.remove("animate-pulse");
                        animateCounterOnLoad(0, targetSlots, 2000);
                    } else if (fetchedCount !== targetSlots) {
                        targetSlots = fetchedCount;
                        rollToNewNumber(targetSlots);
                    }
                }
            } catch (error) { console.error("Fetch error:", error); }
        }

        window.addEventListener('DOMContentLoaded', () => {
            currentEl.classList.add("animate-pulse");
            fetchLiveCount(true); 
            setInterval(() => { fetchLiveCount(false); }, 30000);
        });

        document.getElementById('registrationForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const submitBtn = document.getElementById('submitBtn');
            const statusMsg = document.getElementById('statusMessage');
            const mobileInput = document.getElementById('mobileNumber').value;
            
            const mobileRegex = /^\+?[0-9]{10,15}$/;
            if(!mobileRegex.test(mobileInput.replace(/\s+/g, ''))) {
                statusMsg.classList.remove('hidden');
                statusMsg.innerHTML = "ACCESS DENIED: INVALID WHATSAPP NUMBER.";
                statusMsg.className = "text-center mt-6 text-sm font-bold tracking-widest p-4 rounded border border-red-500 text-red-500 bg-red-500/10";
                return;
            }

            const payload = {
                gameName: document.getElementById('gameName').value,
                gameUid: document.getElementById('gameUid').value,
                mobileNumber: mobileInput,
                uniqueCode: document.getElementById('uniqueCode').value.toUpperCase()
            };

            submitBtn.disabled = true;
            submitBtn.innerHTML = `<svg class="animate-spin h-5 w-5 text-gold" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>`;
            statusMsg.classList.add('hidden');

            try {
                const response = await fetch(SCRIPT_URL, {
                    method: 'POST',
                    body: JSON.stringify(payload),
                    headers: { 'Content-Type': 'text/plain;charset=utf-8' }
                });

                const result = await response.json();

                statusMsg.classList.remove('hidden');
                if (result.status === 'success') {
                    statusMsg.innerHTML = "ENTRY AUTHORIZED. SLOT SECURED.";
                    statusMsg.className = "text-center mt-6 text-sm font-bold tracking-widest p-4 rounded border border-gold text-gold bg-gold/10";
                    document.getElementById('registrationForm').reset();
                    targetSlots += 1;
                    rollToNewNumber(targetSlots);
                } else {
                    statusMsg.innerHTML = "ACCESS DENIED: " + result.message;
                    statusMsg.className = "text-center mt-6 text-sm font-bold tracking-widest p-4 rounded border border-red-500 text-red-500 bg-red-500/10";
                }
            } catch (error) {
                statusMsg.classList.remove('hidden');
                statusMsg.innerHTML = "COMMUNICATION FAILURE. RETRY.";
                statusMsg.className = "text-center mt-6 text-sm font-bold tracking-widest p-4 rounded border border-red-500 text-red-500 bg-red-500/10";
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = `<span>Confirm Your Slot</span>`;
            }
        });
    </script>
